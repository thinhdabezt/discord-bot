# Discord
DISCORD_TOKEN=replace_with_your_bot_token
DISCORD_GUILD_ID=replace_with_dev_guild_id

# Database
POSTGRES_DB=discordbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
CONNECTIONSTRINGS__DEFAULT=Host=localhost;Port=55432;Database=discordbot;Username=postgres;Password=postgres

# RSS bridge
RSSBRIDGE__BASEURL=http://localhost:3000

# Feed providers
FEEDPROVIDERS__ENABLEDIRECTRSS=true
FEEDPROVIDERS__ENABLERSSHUB=false
FEEDPROVIDERS__RSSHUBBASEURL=http://localhost:1200
FEEDPROVIDERS__DEFAULTXPROVIDER=RssBridge
FEEDPROVIDERS__DEFAULTFACEBOOKPROVIDER=RssHub
FEEDPROVIDERS__ENABLEFACEBOOKPROFILEALERTS=false
FEEDPROVIDERS__FACEBOOKPROFILEALERTCHANNELID=0
FEEDPROVIDERS__FACEBOOKPROFILEFAILURETHRESHOLD=3
FEEDPROVIDERS__FACEBOOKPROFILEALERTCOOLDOWNMINUTES=180

# Apify fallback for Facebook
APIFYFALLBACK__ENABLED=false
APIFYFALLBACK__APIBASEURL=https://api.apify.com/v2
APIFYFALLBACK__APITOKEN=
APIFYFALLBACK__ACTORID=apify/facebook-posts-scraper
APIFYFALLBACK__RESULTSLIMIT=5
APIFYFALLBACK__REQUESTTIMEOUTSECONDS=45
APIFYFALLBACK__POLLINTERVALSECONDS=5
APIFYFALLBACK__MAXPOLLATTEMPTS=24
APIFYFALLBACK__FAILURETHRESHOLD=3
APIFYFALLBACK__COOLDOWNMINUTES=180
APIFYFALLBACK__ENABLEFORFANPAGE=true
APIFYFALLBACK__ENABLEFORPROFILE=true

# RSS-Bridge priority fallback for Facebook
RSSBRIDGEFALLBACK__ENABLED=false
RSSBRIDGEFALLBACK__FAILURETHRESHOLD=2
RSSBRIDGEFALLBACK__COOLDOWNMINUTES=60
RSSBRIDGEFALLBACK__ENABLEFORFANPAGE=true
RSSBRIDGEFALLBACK__ENABLEFORPROFILE=false

# RSSHub Facebook profile support
FB_COOKIE=
FB_PAGES_LIMIT=3

# Polling
POLLING__INTERVALMINUTES=10
POLLING__MAXITEMSPERFEED=5

# Retry
RETRY__MAXRETRIES=3
RETRY__PUBLISHMAXRETRIES=2
RETRY__INITIALDELAYSECONDS=2

# Publish
PUBLISH__MAXCONCURRENTPUBLISHES=2
PUBLISH__INTERPUBLISHDELAYMS=200
PUBLISH__MAXADDITIONALIMAGES=3
