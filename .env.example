# Discord
DISCORD_TOKEN=replace_with_your_bot_token
DISCORD_GUILD_ID=replace_with_dev_guild_id

# Database
POSTGRES_DB=discordbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
CONNECTIONSTRINGS__DEFAULT=Host=localhost;Port=55432;Database=discordbot;Username=postgres;Password=postgres

# RSS bridge
RSSBRIDGE__BASEURL=http://localhost:3000

# Polling
POLLING__INTERVALMINUTES=10
POLLING__MAXITEMSPERFEED=5

# Retry
RETRY__MAXRETRIES=3
RETRY__PUBLISHMAXRETRIES=2
RETRY__INITIALDELAYSECONDS=2

# Publish
PUBLISH__MAXCONCURRENTPUBLISHES=2
PUBLISH__INTERPUBLISHDELAYMS=200
PUBLISH__MAXADDITIONALIMAGES=3
