# Local Docker/source-run example
# Copy to .env and replace placeholders before running locally.

# 1. Discord
DISCORD_TOKEN=replace_with_your_bot_token
DISCORD_GUILD_ID=replace_with_dev_guild_id

# 2. Database
POSTGRES_DB=discordbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
CONNECTIONSTRINGS__DEFAULT=Host=localhost;Port=55432;Database=discordbot;Username=postgres;Password=postgres

# 3. RSS-Bridge (X/Twitter and Instagram)
RSSBRIDGE__BASEURL=http://localhost:3000
RSSBRIDGE__ENABLENITTERFALLBACK=true
RSSBRIDGE__NITTERBASEURL=https://nitter.net

# 4. Feed providers
FEEDPROVIDERS__ENABLEDIRECTRSS=true
FEEDPROVIDERS__DEFAULTXPROVIDER=RssBridge

# 5. Apify primary for Facebook /add-fb
APIFY__ENABLED=false
APIFY__APIBASEURL=https://api.apify.com/v2
APIFY__APITOKEN=
APIFY__ACTORID=apify/facebook-posts-scraper
APIFY__RESULTSLIMIT=5
APIFY__REQUESTTIMEOUTSECONDS=45
APIFY__POLLINTERVALSECONDS=5
APIFY__MAXPOLLATTEMPTS=24
APIFY__ENABLEFORFANPAGE=true
APIFY__ENABLEFORPROFILE=true

# 6. Polling
POLLING__INTERVALMINUTES=10
POLLING__MAXITEMSPERFEED=5

# 7. Retry
RETRY__MAXRETRIES=3
RETRY__PUBLISHMAXRETRIES=2
RETRY__INITIALDELAYSECONDS=2

# 8. Publish
PUBLISH__MAXCONCURRENTPUBLISHES=2
PUBLISH__INTERPUBLISHDELAYMS=200
PUBLISH__MAXADDITIONALIMAGES=3
