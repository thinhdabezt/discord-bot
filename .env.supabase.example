# Source-run / Supabase direct database example
# Copy selected values into your runtime environment.

# 1. Discord
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_GUILD_ID=123456789012345678

# 2. Database
# Supabase direct connection format:
# Host=db.<project-ref>.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=<database-password>;SSL Mode=Require;Trust Server Certificate=true
# Direct connections require IPv6 support, or Supabase IPv4 add-on. Use session pooler if your network is IPv4-only.
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_PASSWORD
CONNECTIONSTRINGS__DEFAULT=Host=db.YOUR_PROJECT_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# 3. RSS-Bridge
RSSBRIDGE__BASEURL=http://localhost:3000
RSSBRIDGE__ENABLENITTERFALLBACK=true
RSSBRIDGE__NITTERBASEURL=https://nitter.net

# 4. Feed providers
FEEDPROVIDERS__ENABLEDIRECTRSS=true
FEEDPROVIDERS__DEFAULTXPROVIDER=RssBridge

# 5. Apify primary for Facebook /add-fb
APIFY__ENABLED=true
APIFY__APIBASEURL=https://api.apify.com/v2
APIFY__APITOKEN=
APIFY__ACTORID=apify/facebook-posts-scraper
APIFY__RESULTSLIMIT=5
APIFY__REQUESTTIMEOUTSECONDS=45
APIFY__POLLINTERVALSECONDS=5
APIFY__MAXPOLLATTEMPTS=24
APIFY__ENABLEFORFANPAGE=true
APIFY__ENABLEFORPROFILE=true

# 6. Polling
POLLING__INTERVALMINUTES=10
POLLING__MAXITEMSPERFEED=5

# 7. Retry
RETRY__MAXRETRIES=3
RETRY__PUBLISHMAXRETRIES=2
RETRY__INITIALDELAYSECONDS=2

# 8. Publish
PUBLISH__MAXCONCURRENTPUBLISHES=2
PUBLISH__INTERPUBLISHDELAYMS=200
PUBLISH__MAXADDITIONALIMAGES=3
