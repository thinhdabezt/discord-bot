# Source-run / external database (Supabase or managed Postgres)
# Copy selected values into your runtime environment.

# Required
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
CONNECTIONSTRINGS__DEFAULT=Host=YOUR_HOST;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
RSSBRIDGE__BASEURL=http://localhost:3000

# Recommended
DISCORD_GUILD_ID=123456789012345678

# Optional tuning
POLLING__INTERVALMINUTES=10
POLLING__MAXITEMSPERFEED=5
RETRY__MAXRETRIES=3
RETRY__PUBLISHMAXRETRIES=2
RETRY__INITIALDELAYSECONDS=2
PUBLISH__MAXCONCURRENTPUBLISHES=2
PUBLISH__INTERPUBLISHDELAYMS=200
PUBLISH__MAXADDITIONALIMAGES=3
