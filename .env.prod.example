# Production Docker Compose example
# Copy to .env and replace placeholders before deploy.

# Required
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Recommended
DISCORD_GUILD_ID=123456789012345678
POSTGRES_DB=discordbot
POSTGRES_USER=postgres

# Optional tuning
RSSBRIDGE__ENABLENITTERFALLBACK=true
RSSBRIDGE__NITTERBASEURL=https://nitter.net
FEEDPROVIDERS__ENABLEDIRECTRSS=true
FEEDPROVIDERS__ENABLERSSHUB=false
FEEDPROVIDERS__RSSHUBBASEURL=http://rsshub:1200
FEEDPROVIDERS__DEFAULTXPROVIDER=RssBridge
FEEDPROVIDERS__DEFAULTFACEBOOKPROVIDER=RssHub
POLLING__INTERVALMINUTES=10
POLLING__MAXITEMSPERFEED=5
RETRY__MAXRETRIES=3
RETRY__PUBLISHMAXRETRIES=2
RETRY__INITIALDELAYSECONDS=2
PUBLISH__MAXCONCURRENTPUBLISHES=2
PUBLISH__INTERPUBLISHDELAYMS=200
PUBLISH__MAXADDITIONALIMAGES=3
