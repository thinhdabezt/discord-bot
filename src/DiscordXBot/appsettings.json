{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=55432;Database=discordbot;Username=postgres;Password=postgres"
  },
  "Discord": {
    "Token": "",
    "DevGuildId": null
  },
  "RssBridge": {
    "BaseUrl": "http://localhost:3000"
  },
  "FeedProviders": {
    "EnableDirectRss": true,
    "EnableRssHub": false,
    "RssHubBaseUrl": "http://localhost:1200",
    "DefaultXProvider": "RssBridge",
    "DefaultFacebookProvider": "RssHub"
  },
  "Polling": {
    "IntervalMinutes": 10,
    "MaxItemsPerFeed": 5
  },
  "Retry": {
    "MaxRetries": 3,
    "PublishMaxRetries": 2,
    "InitialDelaySeconds": 2
  },
  "Publish": {
    "MaxConcurrentPublishes": 2,
    "InterPublishDelayMs": 200,
    "MaxAdditionalImages": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
